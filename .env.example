# Copy to .env.local and fill in real values. See src/config/env.ts for
# validation rules — the app refuses to boot if any of these are
# missing or malformed.

# --- Database (Prisma / PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/ai_presentation_consultant"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_presentation_consultant"

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_WEBHOOK_SECRET=""

# --- Storage (Supabase) ---
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="presentations"

# --- AI Providers (configuration only — no calls made in Sprint 0) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_DEFAULT_PROVIDER="anthropic"
AI_DEFAULT_MODEL="claude-sonnet-4-6"
AI_REQUEST_TIMEOUT_MS="30000"
AI_MAX_RETRIES="2"

# --- App ---
APP_URL="http://localhost:3000"
LOG_LEVEL="info"
NODE_ENV="development"
